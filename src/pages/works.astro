---
import Layout from "../layouts/Layout.astro";
import PageTitle from "../components/shared/page/PageTitle";
import PageContainer from "../components/shared/page/PageContainer";
import WorksCard from "../components/shared/card/WorksCard.astro";
import { getAllWorks, type Work as MicroCMSWork } from "../lib/microcms";
import { ZoomableFlavorWheel } from "../components/features/flavor-wheel";
import { flavorWheelSegments } from "../data/flavor-wheel-segments";
import "../components/shared/page/page-title.css";
import "../components/shared/page/page-container.css";
import "../components/shared/card/overlay-card.css";

// microCMSからworksデータを取得
const worksResponse = await getAllWorks();
const allWorks = worksResponse.contents;

// 表示用のWork型に変換
interface DisplayWork {
    title: string;
    subtitle?: string;
    url: string;
    githubUrl?: string;
    type: "personal" | "organization";
    genre?: "programming" | "design";
    photos?: {
        url: string;
        height: number;
        width: number;
    }[];
}

// 配列または文字列から最初の値を取得するヘルパー関数
function getFirstValue<T>(value: T | T[] | undefined): T | undefined {
    if (value === undefined) return undefined;
    if (Array.isArray(value)) return value[0];
    return value;
}

const mapToDisplayWork = (work: MicroCMSWork): DisplayWork | null => {
    // 配列から最初の値を取得
    const genre = getFirstValue(work.genre);
    const owner = getFirstValue(work.owner);
    
    // programmingの場合はlinkが必須、designの場合はphotosまたはlinkがあればOK
    if (genre === "programming" && !work.link) {
        return null;
    }
    
    if (genre === "design" && !work.photos && !work.link) {
        return null;
    }
    
    // genreが未設定の場合は、linkがあれば表示する
    if (!genre && !work.link) {
        return null;
    }
    
    // designでlinkがない場合は、photosの最初の画像のURLをダミーURLとして使用
    const url = work.link || (work.photos && work.photos.length > 0 ? "#" : "#");

    return {
        title: work.title,
        subtitle: work.outline,
        url: url,
        githubUrl: work.githuburl,
        type: owner || "personal",
        genre: genre,
        photos: work.photos,
    };
};

const displayWorks = allWorks
    .map(mapToDisplayWork)
    .filter((work): work is DisplayWork => work !== null);

const personalWorks = displayWorks.filter(work => work.type === "personal");
const organizationWorks = displayWorks.filter(work => work.type === "organization");
---

<Layout title="Works">
    <PageContainer variant="works">
        <PageTitle title="WORKS" client:load />
        
        {personalWorks.length > 0 && (
            <section class="works-section">
                <h2 class="works-section-title">Individual Works</h2>
                <div class="works-grid">
                    {personalWorks.map((work) => (
                        <WorksCard
                            title={work.title}
                            subtitle={work.subtitle}
                            url={work.url}
                            githubUrl={work.githubUrl}
                            genre={work.genre}
                            photos={work.photos}
                        />
                    ))}
                </div>
            </section>
        )}

        {organizationWorks.length > 0 && (
            <section class="works-section">
                <h2 class="works-section-title">団体作品</h2>
                <div class="works-grid">
                    {organizationWorks.map((work) => (
                        <WorksCard
                            title={work.title}
                            subtitle={work.subtitle}
                            url={work.url}
                            githubUrl={work.githubUrl}
                            genre={work.genre}
                            photos={work.photos}
                        />
                    ))}
                </div>
            </section>
        )}
        <section class="works-section">
            <h2 class="works-section-title">Flavor Wheel</h2>
            <section class="flavor-wheel-section">
                <ZoomableFlavorWheel
                    segments={flavorWheelSegments}
                    client:only="react"
                />
            </section>
        </section>
    </PageContainer>
</Layout>

<style>
    .flavor-wheel-section {
        margin: 4rem auto 2rem;
        max-width: 600px;
        min-height: 400px;
        border-radius: 0.5rem;
        overflow: hidden;
        box-shadow: 0 1px 3px rgb(0 0 0 / 10%);
    }

    .works-section {
        margin-top: 4rem;
    }

    .works-section:first-of-type {
        margin-top: 3rem;
    }

    .works-section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #1f2937;
        margin: 0 0 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .works-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }

    @media (width <= 47.9375rem) {
        .works-section {
            margin-top: 3rem;
        }

        .works-section:first-of-type {
            margin-top: 2rem;
        }

        .works-section-title {
            font-size: 1.25rem;
            margin: 0 0 1.25rem;
        }

        .works-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .flavor-wheel-section {
            min-height: 300px;
            margin-top: 3rem;
        }
    }
</style>


